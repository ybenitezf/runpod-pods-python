# RunPod API Key (required)
RUNPOD_API_KEY=your_api_key_here

# Pod Configuration (required for template creation)
GPU_TYPE_ID=NVIDIA A40
IMAGE_NAME=pytorch/pytorch:latest

# Template Configuration (optional)
# Container disk size in GB (default: 10)
CONTAINER_DISK_IN_GB=10

# Volume configuration (optional)
# Volume size in GB
# VOLUME_IN_GB=20
# Volume mount path (e.g., /workspace)
# VOLUME_MOUNT_PATH=/workspace

# Port configuration (optional, comma-separated)
# PORTS=22/tcp,8888/http

# Environment variables for template (optional, JSON format)
# TEMPLATE_ENV={"KEY": "value"}
